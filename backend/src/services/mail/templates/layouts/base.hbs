<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    body { margin:0; padding:0; font-family:'Segoe UI',Roboto,sans-serif; background:#f4f4f7; }
    .container { max-width:600px; margin:40px auto; background:#fff; border-radius:12px; overflow:hidden; box-shadow:0 2px 12px rgba(0,0,0,.08); }
    .header { background:linear-gradient(135deg,#0069ff,#5b9dff); padding:32px; text-align:center; }
    .header h1 { margin:0; color:#fff; font-size:24px; letter-spacing:-0.5px; }
    .body { padding:32px; color:#333; line-height:1.6; }
    .footer { padding:24px 32px; text-align:center; font-size:13px; color:#999; border-top:1px solid #eee; }
    .btn { display:inline-block; padding:12px 28px; background:#0069ff; color:#fff!important; border-radius:8px; text-decoration:none; font-weight:600; margin:16px 0; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header"><h1>Calenderly</h1></div>
    <div class="body">{{{body}}}</div>
    <div class="footer">&copy; {{year}} Calenderly. All rights reserved.</div>
  </div>
</body>
</html>
