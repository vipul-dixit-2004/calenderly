<h2>Meeting Rescheduled 📅</h2>
<p>Hi <strong>{{inviteeName}}</strong>,</p>
<p>Your meeting with <strong>{{hostName}}</strong> has been successfully rescheduled.</p>

{{#if reason}}
<div style="background:#f8fafc;padding:12px;border-left:4px solid #f59e0b;margin-bottom:16px;">
  <strong>Reason for rescheduling:</strong><br/>
  {{reason}}
</div>
{{/if}}

<h3>New Meeting Details</h3>
<table style="width:100%;border-collapse:collapse;margin:20px 0">
  <tr><td style="padding:8px 0;color:#666">Event</td><td style="padding:8px 0;font-weight:600">{{eventTitle}}</td></tr>
  <tr><td style="padding:8px 0;color:#666">Old Date & Time</td><td style="padding:8px 0;text-decoration:line-through;color:#94a3b8">{{formatDate oldStartTime}} {{formatTime oldStartTime}}</td></tr>
  <tr><td style="padding:8px 0;color:#666">New Date</td><td style="padding:8px 0;font-weight:600;color:#16a34a">{{formatDate newStartTime}}</td></tr>
  <tr><td style="padding:8px 0;color:#666">New Time</td><td style="padding:8px 0;font-weight:600;color:#16a34a">{{formatTime newStartTime}}</td></tr>
  <tr><td style="padding:8px 0;color:#666">Duration</td><td style="padding:8px 0;font-weight:600">{{duration}} min</td></tr>
</table>

{{#if meetUrl}}
  <p style="margin-top:24px">
    <a href="{{meetUrl}}" style="background:#0069ff;color:#fff;padding:12px 24px;text-decoration:none;border-radius:6px;display:inline-block;font-weight:600">Join Google Meet</a>
  </p>
  <p style="font-size:12px;color:#666;margin-top:8px">Or copy link: {{meetUrl}}</p>
{{else if meetAddress}}
  <p style="margin-top:24px"><strong>Location:</strong> {{meetAddress}}</p>
{{else if meetPhone}}
  <p style="margin-top:24px"><strong>Phone number:</strong> {{meetPhone}}</p>
{{/if}}

<p style="margin-top:20px;border-top:1px solid #eee;padding-top:20px;font-size:14px;color:#666">
  Need to make changes again? <a href="{{appUrl}}/reschedule/{{meetingId}}" style="color:#0069ff;text-decoration:none;font-weight:600">Reschedule</a> or cancel your meeting.
</p>
