<h2 style="margin:0 0 16px;color:#111">Message from {{hostName}}</h2>

<div style="background:#f8f9fa;border-left:4px solid #0069ff;border-radius:4px;padding:16px 20px;margin:0 0 24px;white-space:pre-wrap;font-size:15px;line-height:1.6;color:#333">{{bodyText}}</div>

<table style="width:100%;border-collapse:collapse;margin:0 0 20px">
  <tr style="border-bottom:1px solid #eee">
    <td style="padding:10px 0;color:#666;width:100px">Event</td>
    <td style="padding:10px 0;font-weight:600">{{eventTitle}}</td>
  </tr>
  <tr style="border-bottom:1px solid #eee">
    <td style="padding:10px 0;color:#666">Date</td>
    <td style="padding:10px 0;font-weight:600">{{formatDate startTime}}</td>
  </tr>
  <tr style="border-bottom:1px solid #eee">
    <td style="padding:10px 0;color:#666">Time</td>
    <td style="padding:10px 0;font-weight:600">{{formatTime startTime}} – {{formatTime endTime}}</td>
  </tr>
  <tr>
    <td style="padding:10px 0;color:#666">Duration</td>
    <td style="padding:10px 0;font-weight:600">{{duration}} min</td>
  </tr>
</table>

<p style="margin:0;color:#666;font-size:13px">This message was sent on behalf of <strong>{{hostName}}</strong> via Calenderly.</p>
